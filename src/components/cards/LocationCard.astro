---
interface Props {
  name: string;
  slug: string;
  postcodes?: string[];
  serviceCount?: number;
}

const { name, slug, postcodes = [], serviceCount = 12 } = Astro.props;
---

<a href={`/locations/${slug}`} class="group block bg-white rounded-lg shadow-sm p-6 hover:shadow-md hover:border-l-4 hover:border-l-primary-600 transition-all duration-200">
  <div class="flex items-center gap-3">
    <svg class="w-6 h-6 text-primary-600 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
    </svg>
    <div>
      <h3 class="text-xl font-semibold text-neutral-900 font-heading group-hover:text-primary-600 transition-colors">{name}</h3>
      <p class="text-sm text-neutral-500">
        {postcodes.length > 0 ? postcodes.join(', ') : `${serviceCount} services available`}
      </p>
    </div>
  </div>
</a>

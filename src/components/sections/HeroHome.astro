---
import Button from '../ui/Button.astro';
import { siteConfig, affiliateUrl } from '../../data/site';
---

<section data-hero class="relative min-h-[600px] lg:min-h-[80vh] flex items-center">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="/images/hero/home-hero.webp"
      alt="Man With A Van Sheffield — van being loaded on a Sheffield residential street"
      class="w-full h-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/85 via-neutral-900/40 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-xl">
      <h1 class="text-4xl lg:text-6xl font-bold text-white font-heading leading-tight">
        Man With A Van Sheffield — Fixed Prices, 7 Days a Week
      </h1>
      <p class="mt-6 text-xl text-white/90 max-w-md">
        Local moves, house removals, student moves, and furniture delivery across Sheffield and South Yorkshire. Fixed-price quotes, fully insured, no surprises.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button href={affiliateUrl} variant="primary" size="lg">Get a Free Quote</Button>
        <Button href="/services/" variant="ghost" size="lg" class="text-white hover:bg-white/10">
          Our Services
        </Button>
      </div>

      <!-- Trust Bar -->
      <div class="mt-10 flex items-center gap-3">
        <div class="flex text-secondary-400">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          ))}
        </div>
        <span class="text-white/80 text-sm font-medium">
          {siteConfig.stats.averageRating}/5 from {siteConfig.stats.reviews} reviews
        </span>
      </div>
    </div>
  </div>
</section>

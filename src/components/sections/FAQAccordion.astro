---
interface Props {
  faqs: { question: string; answer: string }[];
  heading?: string;
}

const { faqs, heading = 'Frequently Asked Questions' } = Astro.props;
---

<div class="max-w-3xl mx-auto">
  {heading && (
    <h2 class="text-3xl font-bold text-neutral-900 font-heading text-center mb-12">{heading}</h2>
  )}
  <div class="space-y-6">
    {faqs.map((faq) => (
      <div class="bg-white rounded-lg shadow-sm p-6 border border-neutral-100">
        <h3 class="text-lg font-semibold text-neutral-900 mb-3">{faq.question}</h3>
        <p class="text-base text-neutral-600 leading-relaxed">{faq.answer}</p>
      </div>
    ))}
  </div>
</div>

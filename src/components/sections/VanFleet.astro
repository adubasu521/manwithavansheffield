---
import { siteConfig } from '../../data/site';

interface Props {
  heading?: string;
}

const { heading = 'Our Van Fleet' } = Astro.props;
---

<div>
  <div class="text-center mb-12">
    <h2 class="text-3xl font-bold text-neutral-900 font-heading">{heading}</h2>
    <p class="mt-4 text-lg text-neutral-500">All vans under 3 years old, regularly cleaned and maintained.</p>
  </div>
  <div class="grid md:grid-cols-3 gap-8">
    {siteConfig.vanFleet.map((van) => (
      <div class="bg-white rounded-lg shadow-sm p-6 hover:shadow-md transition-shadow">
        <h3 class="text-xl font-semibold text-neutral-900 font-heading">{van.name}</h3>
        <p class="mt-2 text-sm text-neutral-500">{van.loadSpace}</p>
        <p class="mt-3 text-neutral-600">{van.bestFor}</p>
        <div class="mt-4 pt-4 border-t border-neutral-200 space-y-2">
          <div class="flex justify-between text-sm">
            <span class="text-neutral-500">Self-loading</span>
            <span class="font-semibold text-neutral-900">{van.pricing.selfLoading}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-neutral-500">Driver loading</span>
            <span class="font-semibold text-neutral-900">{van.pricing.driverLoading}</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-neutral-500">Two-man team</span>
            <span class="font-semibold text-primary-600 text-base">{van.pricing.twoMan}</span>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>

---
import ServiceCard from '../cards/ServiceCard.astro';
import type { Service } from '../../data/services';

interface Props {
  services: Service[];
  heading?: string;
  subtitle?: string;
}

const { services, heading = 'Our Services', subtitle = 'Professional removal and delivery services across Leeds and West Yorkshire.' } = Astro.props;
---

<div>
  {heading && (
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-neutral-900 font-heading">{heading}</h2>
      {subtitle && <p class="mt-4 text-lg text-neutral-500 max-w-2xl mx-auto">{subtitle}</p>}
    </div>
  )}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {services.map((service) => (
      <ServiceCard
        name={service.name}
        slug={service.slug}
        description={service.description}
        image={service.image}
      />
    ))}
  </div>
</div>

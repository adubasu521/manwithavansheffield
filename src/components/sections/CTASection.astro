---
import Button from '../ui/Button.astro';
import { siteConfig, affiliateUrl } from '../../data/site';

interface Props {
  heading?: string;
  subtitle?: string;
  subid?: string;
}

const {
  heading = 'Ready to Book Your Move?',
  subtitle = `Get a free, fixed-price quote from Sheffield's most reliable man and van service. Call us today or fill out our online form.`,
  subid = 'cta-section',
} = Astro.props;
---

<section class="bg-primary-600 py-16 md:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl font-bold text-white font-heading">{heading}</h2>
    <p class="mt-4 text-lg text-white/80 max-w-xl mx-auto">{subtitle}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <Button href={affiliateUrl} variant="white" size="lg">Get a Free Quote</Button>
      <Button href={`tel:${siteConfig.phoneTel}`} variant="outline" size="lg" class="border-white text-white hover:bg-white hover:text-primary-600">
        Call {siteConfig.phoneDisplay}
      </Button>
    </div>
  </div>
</section>

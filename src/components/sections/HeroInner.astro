---
import Breadcrumbs from './Breadcrumbs.astro';

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs: { label: string; href: string }[];
  backgroundImage?: string;
}

const { title, subtitle, breadcrumbs, backgroundImage = '/images/hero/inner-default.webp' } = Astro.props;
---

<section class="relative h-[240px] md:h-[320px] flex items-center">
  <div class="absolute inset-0">
    <img
      src={backgroundImage}
      alt=""
      class="w-full h-full object-cover"
      width="1920"
      height="400"
      loading="eager"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-primary-600/85"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center w-full">
    <Breadcrumbs items={breadcrumbs} dark />
    <h1 class="text-3xl md:text-4xl font-bold text-white font-heading mt-3">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-3 text-lg text-white/80 max-w-2xl mx-auto">{subtitle}</p>
    )}
  </div>
</section>

---
import type { Location } from '../../data/locations';

interface Props {
  locations: Location[];
  currentService?: string;
  heading?: string;
}

const { locations, currentService, heading = 'Nearby Service Areas' } = Astro.props;
---

<div>
  <h2 class="text-2xl font-bold text-neutral-900 font-heading mb-6">{heading}</h2>
  <div class="flex flex-wrap gap-3">
    {locations.map((loc) => (
      <a
        href={currentService ? `/${loc.slug}/${currentService}` : `/locations/${loc.slug}`}
        class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full shadow-sm text-sm font-medium text-neutral-700 hover:text-primary-600 hover:shadow-md transition-all"
      >
        <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
        </svg>
        {loc.name}
      </a>
    ))}
  </div>
</div>

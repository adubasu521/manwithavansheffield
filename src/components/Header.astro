---
import { siteConfig, affiliateUrl } from '../data/site';
import { services } from '../data/services';
import { locations } from '../data/locations';
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 bg-primary-800 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[64px] lg:h-[72px]">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 text-xl font-bold font-heading text-white transition-colors duration-200">
        <svg class="w-8 h-8" viewBox="0 0 32 32" fill="currentColor">
          <path d="M2 22h2v-4h5v4h2v-6l-1-1H9V9h3V7H8v6H5V7H3v8H2l-1 1v6h1zm26-8h-4v-2h-2v2h-4l2 4v6h2v-4h2v4h2v-6l2-4zM14 24h4v2h-4zM13 20h6l1-2h-8l1 2zm-1-4h8l1-2H11l1 2zm-1-4h10l1-2H10l1 2zm-1-4h12V6H10v2z"/>
        </svg>
        Man With A Van Sheffield
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-8">
        <!-- Services Dropdown -->
        <div class="relative group">
          <a href="/services/" class="text-white font-medium transition-colors duration-200 flex items-center gap-1 py-2 hover:text-primary-200">
            Services
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-neutral-200 p-4 grid grid-cols-2 gap-1 w-[420px]">
              {services.map((service) => (
                <a href={`/services/${service.slug}/`} class="px-3 py-2 rounded-md text-sm text-neutral-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">
                  {service.name}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Areas Dropdown -->
        <div class="relative group">
          <a href="/locations/" class="text-white font-medium transition-colors duration-200 flex items-center gap-1 py-2 hover:text-primary-200">
            Areas
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </a>
          <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
            <div class="bg-white rounded-lg shadow-lg border border-neutral-200 p-4 w-[420px]">
              <p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-2 px-3">Sheffield Districts</p>
              <div class="grid grid-cols-2 gap-1 mb-3">
                {locations.filter(loc => ['sheffield-city-centre','hillsborough','ecclesall','crosspool','crookes','walkley','nether-edge','woodseats'].includes(loc.slug)).map((loc) => (
                  <a href={`/locations/${loc.slug}/`} class="px-3 py-2 rounded-md text-sm text-neutral-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">
                    {loc.name}
                  </a>
                ))}
              </div>
              <p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-2 px-3 border-t border-neutral-100 pt-3">Wider Area</p>
              <div class="grid grid-cols-2 gap-1">
                {locations.filter(loc => ['gleadless','beighton','mosborough','totley','dore','fulwood','stocksbridge','rotherham'].includes(loc.slug)).map((loc) => (
                  <a href={`/locations/${loc.slug}/`} class="px-3 py-2 rounded-md text-sm text-neutral-700 hover:bg-primary-50 hover:text-primary-600 transition-colors">
                    {loc.name}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <a href="/routes/" class="text-white font-medium transition-colors duration-200 hover:text-primary-200">Routes</a>
        <a href="/about/" class="text-white font-medium transition-colors duration-200 hover:text-primary-200">About</a>
        <a href="/blog/" class="text-white font-medium transition-colors duration-200 hover:text-primary-200">Blog</a>
        <a href={affiliateUrl} class="inline-flex items-center px-5 py-2 bg-secondary-500 text-white font-semibold rounded-md hover:bg-secondary-600 hover:shadow-md transition-all duration-150 text-sm">
          Get a Free Quote
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[60] bg-white transform translate-x-full transition-transform duration-300 lg:hidden">
  <div class="flex items-center justify-between h-[64px] px-4 border-b border-neutral-200 bg-primary-800">
    <span class="text-xl font-bold font-heading text-white">Menu</span>
    <button id="mobile-menu-close" class="p-2 text-white" aria-label="Close menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <nav class="px-4 py-6 overflow-y-auto" style="max-height: calc(100vh - 64px - 80px)">
    <div class="space-y-1">
      <a href="/" class="block px-4 py-3 text-lg font-medium text-neutral-900 hover:bg-primary-50 rounded-md">Home</a>

      <p class="px-4 pt-4 pb-2 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Services</p>
      {services.map((service) => (
        <a href={`/services/${service.slug}/`} class="block px-4 py-2 text-neutral-700 hover:bg-primary-50 rounded-md">
          {service.name}
        </a>
      ))}

      <p class="px-4 pt-4 pb-2 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Sheffield Districts</p>
      {locations.filter(loc => ['sheffield-city-centre','hillsborough','ecclesall','crosspool','crookes','walkley','nether-edge','woodseats'].includes(loc.slug)).map((loc) => (
        <a href={`/locations/${loc.slug}/`} class="block px-4 py-2 text-neutral-700 hover:bg-primary-50 rounded-md">
          {loc.name}
        </a>
      ))}

      <p class="px-4 pt-4 pb-2 text-xs font-semibold text-neutral-500 uppercase tracking-wider">Wider Area</p>
      {locations.filter(loc => ['gleadless','beighton','mosborough','totley','dore','fulwood','stocksbridge','rotherham'].includes(loc.slug)).map((loc) => (
        <a href={`/locations/${loc.slug}/`} class="block px-4 py-2 text-neutral-700 hover:bg-primary-50 rounded-md">
          {loc.name}
        </a>
      ))}

      <div class="border-t border-neutral-200 mt-4 pt-4 space-y-1">
        <a href="/routes/" class="block px-4 py-3 text-lg font-medium text-neutral-900 hover:bg-primary-50 rounded-md">Routes</a>
        <a href="/about/" class="block px-4 py-3 text-lg font-medium text-neutral-900 hover:bg-primary-50 rounded-md">About</a>
        <a href="/blog/" class="block px-4 py-3 text-lg font-medium text-neutral-900 hover:bg-primary-50 rounded-md">Blog</a>
      </div>
    </div>
  </nav>
</div>

<!-- Mobile Sticky CTA (bottom of screen, mobile only) -->
<div class="fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-white border-t border-neutral-200 shadow-lg px-4 py-3 flex gap-3">
  <a
    href={affiliateUrl}
    class="flex-1 flex items-center justify-center gap-2 bg-secondary-500 hover:bg-secondary-600 text-white font-semibold rounded-lg py-3 text-sm transition-colors"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
    </svg>
    Quote Now
  </a>
  <a
    href={`tel:${siteConfig.phoneTel}`}
    class="flex-1 flex items-center justify-center gap-2 bg-primary-700 hover:bg-primary-800 text-white font-semibold rounded-lg py-3 text-sm transition-colors"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
    </svg>
    Call Now
  </a>
</div>

<!-- Spacer for fixed header -->
<div class="h-[64px] lg:h-[72px]"></div>

<!-- Spacer for mobile sticky CTA -->
<div class="h-[72px] lg:hidden"></div>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileMenuClose = document.getElementById('mobile-menu-close');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.remove('translate-x-full');
    document.body.classList.add('overflow-hidden');
  });
  mobileMenuClose?.addEventListener('click', () => {
    mobileMenu?.classList.add('translate-x-full');
    document.body.classList.remove('overflow-hidden');
  });
</script>

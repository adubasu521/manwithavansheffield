---
import { siteConfig } from '../data/site';
import { services } from '../data/services';
import { locations } from '../data/locations';
---

<footer class="bg-neutral-900 text-neutral-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand Column -->
      <div>
        <a href="/" class="text-xl font-bold font-heading text-white flex items-center gap-2">
          <svg class="w-7 h-7" viewBox="0 0 32 32" fill="currentColor">
            <path d="M2 22h2v-4h5v4h2v-6l-1-1H9V9h3V7H8v6H5V7H3v8H2l-1 1v6h1zm26-8h-4v-2h-2v2h-4l2 4v6h2v-4h2v4h2v-6l2-4zM14 24h4v2h-4zM13 20h6l1-2h-8l1 2zm-1-4h8l1-2H11l1 2zm-1-4h10l1-2H10l1 2zm-1-4h12V6H10v2z"/>
          </svg>
          Man With A Van Sheffield
        </a>
        <p class="mt-4 text-sm text-neutral-400 leading-relaxed">
          Sheffield's trusted man and van service. Fixed-price quotes, fully insured, available 7 days a week. Local moves, house removals, and long-distance relocations across the UK.
        </p>
        <div class="flex gap-4 mt-6">
          <a href={siteConfig.social.facebook} class="text-neutral-400 hover:text-primary-400 transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={siteConfig.social.google} class="text-neutral-400 hover:text-primary-400 transition-colors" aria-label="Google Business">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          </a>
          <a href={siteConfig.social.trustpilot} class="text-neutral-400 hover:text-primary-400 transition-colors" aria-label="Trustpilot">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1l3.09 6.26L22 8.27l-5 4.87 1.18 6.88L12 16.77l-6.18 3.25L7 13.14 2 8.27l6.91-1.01L12 1z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services Column -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-4 font-heading">Services</h3>
        <ul class="space-y-2">
          {services.map((service) => (
            <li>
              <a href={`/services/${service.slug}/`} class="text-sm text-neutral-300 hover:text-primary-400 transition-colors">
                {service.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Areas Column -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-4 font-heading">Service Areas</h3>
        <ul class="space-y-2">
          {locations.map((loc) => (
            <li>
              <a href={`/locations/${loc.slug}/`} class="text-sm text-neutral-300 hover:text-primary-400 transition-colors">
                {loc.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-4 font-heading">Contact</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <a href={`tel:${siteConfig.phoneTel}`} class="text-neutral-300 hover:text-primary-400 transition-colors">{siteConfig.phoneDisplay}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            <a href={`mailto:${siteConfig.email}`} class="text-neutral-300 hover:text-primary-400 transition-colors break-all">{siteConfig.email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>{siteConfig.address.city}, {siteConfig.address.region} {siteConfig.address.postcode}</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>7 Days a Week: 7:00 AM - 7:00 PM</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-neutral-700 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-500">&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/privacy/" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">Privacy Policy</a>
        <a href="/terms/" class="text-sm text-neutral-500 hover:text-neutral-300 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroInner from '../components/sections/HeroInner.astro';
import GoogleMap from '../components/sections/GoogleMap.astro';
import Section from '../components/ui/Section.astro';
import Container from '../components/ui/Container.astro';
import { siteConfig } from '../data/site';
---

<BaseLayout
  title="Get a Free Quote | Man With A Van Sheffield | 020 3318 4720"
  description="Request a free, fixed-price quote for your Sheffield move. Fill in the form or call 020 3318 4720. Available 7 days a week, 7 AM–7 PM."
  canonical="https://manwithavansheffield.co.uk/contact"
>
  <HeroInner
    title="Get a Free Quote"
    subtitle="Fixed-price quotes with no obligation. Fill in the form below or call us directly — we'll get back to you within a few hours."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
  />

  <Section>
    <Container>
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Form -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-bold text-neutral-900 font-heading mb-6">Request a Quote</h2>

          <form id="contact-form" class="space-y-6">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Full Name <span class="text-red-500">*</span></label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone Number <span class="text-red-500">*</span></label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  autocomplete="tel"
                  class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                  placeholder="07xxx xxxxxx"
                />
              </div>
            </div>

            <div>
              <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email Address <span class="text-red-500">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                placeholder="your@email.com"
              />
            </div>

            <div>
              <label for="service" class="block text-sm font-medium text-neutral-700 mb-1">Service Type</label>
              <select
                id="service"
                name="service"
                class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent bg-white"
              >
                <option value="">Select a service...</option>
                <option value="Man and Van">Man and Van (Local)</option>
                <option value="House Removals">House Removals</option>
                <option value="Long-Distance Removals">Long-Distance Removals</option>
                <option value="Student Moves">Student Moves</option>
                <option value="IKEA Delivery">IKEA Delivery</option>
                <option value="Furniture Delivery">Furniture Delivery</option>
                <option value="Office Removals">Office Removals</option>
                <option value="Packing Service">Packing Service</option>
                <option value="Piano Moving">Piano Moving</option>
                <option value="Fragile Items">Fragile Items Removals</option>
                <option value="Clearance">Clearance &amp; Collections</option>
                <option value="Storage">Storage</option>
                <option value="Other">Other / Not Sure</option>
              </select>
            </div>

            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label for="fromPostcode" class="block text-sm font-medium text-neutral-700 mb-1">From Postcode</label>
                <input
                  type="text"
                  id="fromPostcode"
                  name="fromPostcode"
                  autocomplete="postal-code"
                  class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent uppercase"
                  placeholder="e.g. S6 1AB"
                />
              </div>
              <div>
                <label for="toPostcode" class="block text-sm font-medium text-neutral-700 mb-1">To Postcode</label>
                <input
                  type="text"
                  id="toPostcode"
                  name="toPostcode"
                  class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent uppercase"
                  placeholder="e.g. S1 4AP"
                />
              </div>
            </div>

            <div>
              <label for="movingDate" class="block text-sm font-medium text-neutral-700 mb-1">Preferred Moving Date</label>
              <input
                type="date"
                id="movingDate"
                name="movingDate"
                class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">Additional Details</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full border border-neutral-300 rounded-lg px-4 py-2.5 text-neutral-900 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
                placeholder="Tell us about your move — number of rooms, any large items, floors, lift access, etc."
              ></textarea>
            </div>

            <!-- Error / Success Messages -->
            <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm"></div>
            <div id="form-success" class="hidden bg-green-50 border border-green-200 text-green-700 rounded-lg px-4 py-3 text-sm">
              <strong>Thank you!</strong> We've received your enquiry and will be in touch within a few hours. If you need to speak to us urgently, call <a href={`tel:${siteConfig.phoneTel}`} class="underline">{siteConfig.phoneDisplay}</a>.
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="w-full bg-primary-600 hover:bg-primary-700 disabled:bg-primary-400 text-white font-semibold py-3 px-6 rounded-lg transition-colors flex items-center justify-center gap-2"
            >
              <span id="submit-text">Send Quote Request</span>
              <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
            </button>
          </form>
        </div>

        <!-- Sidebar Contact Info -->
        <div class="space-y-6">
          <div class="bg-primary-50 border border-primary-200 rounded-xl p-6">
            <h3 class="text-lg font-bold text-primary-900 font-heading mb-4">Contact Us Directly</h3>
            <div class="space-y-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-600 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-primary-600 font-medium uppercase tracking-wide">Phone</div>
                  <a href={`tel:${siteConfig.phoneTel}`} class="text-primary-900 font-bold hover:underline">{siteConfig.phoneDisplay}</a>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-primary-600 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-primary-600 font-medium uppercase tracking-wide">Email</div>
                  <a href={`mailto:${siteConfig.email}`} class="text-primary-900 font-bold hover:underline text-sm">{siteConfig.email}</a>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-primary-600 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-primary-600 font-medium uppercase tracking-wide">Hours</div>
                  <div class="text-primary-900 font-semibold text-sm">7 Days a Week</div>
                  <div class="text-primary-700 text-sm">7:00 AM – 7:00 PM</div>
                </div>
              </div>

              <div class="flex items-start gap-3">
                <div class="w-10 h-10 bg-primary-600 rounded-lg flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  </svg>
                </div>
                <div>
                  <div class="text-xs text-primary-600 font-medium uppercase tracking-wide">Based In</div>
                  <div class="text-primary-900 font-semibold text-sm">{siteConfig.address.city}, {siteConfig.address.region}</div>
                  <div class="text-primary-700 text-sm">{siteConfig.address.postcode}</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Response Time -->
          <div class="bg-secondary-50 border border-secondary-200 rounded-xl p-5">
            <h3 class="font-bold text-secondary-900 mb-1">Quick Response Guaranteed</h3>
            <p class="text-secondary-700 text-sm">We aim to respond to all online enquiries within 2 hours during our opening hours. For urgent same-day requests, please call us directly.</p>
          </div>

          <!-- Map -->
          <div>
            <h3 class="text-lg font-bold text-neutral-900 font-heading mb-3">Our Area</h3>
            <GoogleMap
              latitude={siteConfig.geo.latitude}
              longitude={siteConfig.geo.longitude}
              title="Man With A Van Sheffield"
              zoom={11}
            />
          </div>
        </div>
      </div>
    </Container>
  </Section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text')!;
  const submitSpinner = document.getElementById('submit-spinner')!;
  const errorDiv = document.getElementById('form-error')!;
  const successDiv = document.getElementById('form-success')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    successDiv.classList.add('hidden');

    submitBtn.disabled = true;
    submitText.textContent = 'Sending...';
    submitSpinner.classList.remove('hidden');

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const json = await res.json();

      if (res.ok && json.success) {
        form.reset();
        successDiv.classList.remove('hidden');
        successDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        errorDiv.textContent = json.error ?? 'Something went wrong. Please try again or call us directly.';
        errorDiv.classList.remove('hidden');
      }
    } catch {
      errorDiv.textContent = 'Network error. Please check your connection and try again.';
      errorDiv.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Send Quote Request';
      submitSpinner.classList.add('hidden');
    }
  });
</script>

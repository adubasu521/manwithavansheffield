---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/sections/HeroInner.astro';
import FAQAccordion from '../../components/sections/FAQAccordion.astro';
import CTASection from '../../components/sections/CTASection.astro';
import SchemaFAQ from '../../components/seo/SchemaFAQ.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { routes, getRouteBySlug, getRelatedRoutes } from '../../data/routes';
import { siteConfig, affiliateUrl } from '../../data/site';

export async function getStaticPaths() {
  return routes.map((route) => ({
    params: { route: route.slug },
  }));
}

const { route: slug } = Astro.params;
const route = getRouteBySlug(slug)!;
const relatedRoutes = getRelatedRoutes(route.relatedRoutes);
---

<BaseLayout
  title={route.metaTitle}
  description={route.metaDescription}
  canonical={`https://manwithavansheffield.co.uk/routes/${route.slug}`}
>
  <SchemaFAQ faqs={route.faqs} slot="head" />

  <HeroInner
    title={route.heroHeading}
    subtitle={`${route.distance} · ${route.driveTime} drive · From ${route.typicalCost.split('-')[0]}`}
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Routes', href: '/routes/' },
      { label: `Sheffield to ${route.to}` },
    ]}
  />

  <Section>
    <Container>
      <div class="grid lg:grid-cols-3 gap-12">
        <div class="lg:col-span-2">
          <!-- Intro -->
          <h2 class="text-2xl font-bold text-neutral-900 font-heading mb-4">About This Route</h2>
          <p class="text-lg text-neutral-600 leading-relaxed">{route.intro}</p>

          <!-- Route Details -->
          <div class="mt-8">
            <h2 class="text-2xl font-bold text-neutral-900 font-heading mb-4">Route Details</h2>
            <p class="text-neutral-600 leading-relaxed">{route.routeDetails}</p>
          </div>

          <!-- What Fits -->
          <div class="mt-8">
            <h2 class="text-2xl font-bold text-neutral-900 font-heading mb-6">Choosing the Right Van</h2>
            <div class="space-y-4">
              {route.whatFits.map((option) => (
                <div class="bg-white border border-neutral-200 rounded-xl p-5 shadow-sm">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="font-bold text-neutral-900">{option.van}</h3>
                      <p class="text-sm text-neutral-500 mt-0.5">{option.capacity}</p>
                    </div>
                    <span class="shrink-0 text-xs bg-primary-100 text-primary-800 font-semibold px-3 py-1 rounded-full">
                      Best for
                    </span>
                  </div>
                  <p class="mt-2 text-sm text-neutral-600">{option.bestFor}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Tips -->
          {route.tips && route.tips.length > 0 && (
            <div class="mt-8">
              <h2 class="text-2xl font-bold text-neutral-900 font-heading mb-4">Tips for This Route</h2>
              <ul class="space-y-3">
                {route.tips.map((tip) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-secondary-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                    </svg>
                    <span class="text-neutral-600">{tip}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
          <!-- Quick Facts -->
          <div class="bg-primary-50 border border-primary-200 rounded-xl p-6">
            <h3 class="text-lg font-bold text-primary-900 font-heading mb-4">Quick Facts</h3>
            <dl class="space-y-3">
              <div class="flex justify-between items-center py-2 border-b border-primary-200">
                <dt class="text-primary-700 font-medium text-sm">From</dt>
                <dd class="text-primary-900 font-semibold">{route.from}</dd>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-primary-200">
                <dt class="text-primary-700 font-medium text-sm">To</dt>
                <dd class="text-primary-900 font-semibold">{route.to}</dd>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-primary-200">
                <dt class="text-primary-700 font-medium text-sm">Distance</dt>
                <dd class="text-primary-900 font-semibold">{route.distance}</dd>
              </div>
              <div class="flex justify-between items-center py-2 border-b border-primary-200">
                <dt class="text-primary-700 font-medium text-sm">Drive Time</dt>
                <dd class="text-primary-900 font-semibold">{route.driveTime}</dd>
              </div>
              <div class="flex justify-between items-center py-2">
                <dt class="text-primary-700 font-medium text-sm">Typical Cost</dt>
                <dd class="text-primary-900 font-bold text-lg">{route.typicalCost}</dd>
              </div>
            </dl>
            <a href={affiliateUrl} class="mt-5 block w-full text-center bg-primary-600 hover:bg-primary-700 text-white font-semibold py-3 px-4 rounded-lg transition-colors text-sm">
              Get a Fixed-Price Quote
            </a>
            <a href={`tel:${siteConfig.phoneTel}`} class="mt-2 block w-full text-center border border-primary-400 text-primary-700 hover:bg-primary-100 font-semibold py-3 px-4 rounded-lg transition-colors text-sm">
              Call {siteConfig.phoneDisplay}
            </a>
          </div>

          <!-- What's Included -->
          <div class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-lg font-bold text-neutral-900 font-heading mb-3">What's Included</h3>
            <ul class="space-y-2 text-sm text-neutral-600">
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Dedicated van — your load only
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Goods-in-transit insurance
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Door-to-door collection &amp; delivery
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                Fixed total price — no extras
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-4 h-4 text-secondary-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                2-man crew available
              </li>
            </ul>
          </div>

          <!-- Related Routes -->
          {relatedRoutes.length > 0 && (
            <div class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
              <h3 class="text-lg font-bold text-neutral-900 font-heading mb-3">Other Popular Routes</h3>
              <ul class="space-y-2">
                {relatedRoutes.map((r) => (
                  <li>
                    <a href={`/routes/${r.slug}/`} class="text-primary-600 hover:text-primary-700 text-sm font-medium hover:underline">
                      Sheffield → {r.to} ({r.distance})
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </Container>
  </Section>

  <!-- FAQs -->
  <Section class="bg-neutral-50">
    <Container>
      <FAQAccordion faqs={route.faqs} />
    </Container>
  </Section>

  <CTASection
    heading={`Ready to Move from Sheffield to ${route.to}?`}
    subtitle={`Get a fixed price for your Sheffield to ${route.to} move. No mileage extras, no shared loads — just a straight-forward quote.`}
  />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/sections/HeroInner.astro';
import CTASection from '../../components/sections/CTASection.astro';
import SchemaArticle from '../../components/seo/SchemaArticle.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { blogPosts } from '../../data/blog-posts';
import { services, getServiceBySlug } from '../../data/services';
import { affiliateUrl } from '../../data/site';

export async function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = blogPosts.find((p) => p.slug === slug)!;
const relatedServices = post.relatedServices.map((s) => getServiceBySlug(s)).filter(Boolean);
---

<BaseLayout
  title={post.metaTitle}
  description={post.metaDescription}
  canonical={`https://manwithavansheffield.co.uk/blog/${post.slug}`}
  ogType="article"
  ogImage={post.image}
>
  <SchemaArticle
    headline={post.title}
    description={post.metaDescription}
    datePublished={post.datePublished}
    dateModified={post.dateModified}
    image={post.image}
    slot="head"
  />

  <HeroInner
    title={post.title}
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: post.title },
    ]}
  />

  <Section>
    <Container>
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Article -->
        <article class="lg:col-span-2">
          <!-- Meta -->
          <div class="flex items-center gap-4 mb-6 text-sm text-neutral-500">
            <time datetime={post.datePublished}>
              {new Date(post.datePublished).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            <div class="w-1 h-1 bg-neutral-400 rounded-full"></div>
            <div class="flex flex-wrap gap-2">
              {post.tags.map((tag) => (
                <span class="bg-primary-100 text-primary-700 text-xs font-medium px-2 py-0.5 rounded">{tag}</span>
              ))}
            </div>
          </div>

          <!-- Hero Image -->
          <img
            src={post.image}
            alt={post.title}
            class="w-full rounded-xl mb-8 aspect-video object-cover"
            width="800"
            height="450"
            loading="eager"
          />

          <!-- Content -->
          <div class="prose prose-lg max-w-none prose-headings:font-heading prose-headings:text-neutral-900 prose-p:text-neutral-600 prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline prose-li:text-neutral-600" set:html={post.content} />
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <!-- Author/Trust -->
          <div class="bg-primary-50 border border-primary-200 rounded-xl p-6">
            <h3 class="text-lg font-bold text-primary-900 font-heading mb-2">Man With A Van Sheffield</h3>
            <p class="text-primary-700 text-sm">This guide was written by our experienced Sheffield removal team. We know the city's gradient streets, Supertram restrictions, and student move calendar better than anyone.</p>
            <a href="/about/" class="mt-3 inline-block text-primary-600 text-sm font-semibold hover:underline">About us →</a>
          </div>

          <!-- Related Services -->
          {relatedServices.length > 0 && (
            <div class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
              <h3 class="text-lg font-bold text-neutral-900 font-heading mb-4">Related Services</h3>
              <ul class="space-y-3">
                {relatedServices.map((svc) => svc && (
                  <li>
                    <a href={`/services/${svc.slug}/`} class="flex items-center gap-2 text-primary-600 hover:text-primary-800 font-medium text-sm">
                      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                      {svc.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- CTA Box -->
          <div class="bg-primary-600 rounded-xl p-6 text-white">
            <h3 class="text-lg font-bold font-heading mb-2">Ready to Book?</h3>
            <p class="text-primary-100 text-sm mb-4">Get a free, fixed-price quote for your Sheffield move today.</p>
            <a href={affiliateUrl} class="block w-full text-center bg-white text-primary-700 font-semibold py-2.5 px-4 rounded-lg hover:bg-primary-50 transition-colors text-sm">
              Get a Free Quote
            </a>
          </div>

          <!-- More Posts -->
          <div class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
            <h3 class="text-lg font-bold text-neutral-900 font-heading mb-4">More Guides</h3>
            <ul class="space-y-3">
              {blogPosts.filter((p) => p.slug !== post.slug).slice(0, 3).map((p) => (
                <li>
                  <a href={`/blog/${p.slug}/`} class="text-primary-600 hover:text-primary-800 font-medium text-sm hover:underline">
                    {p.title}
                  </a>
                </li>
              ))}
            </ul>
            <a href="/blog/" class="mt-4 inline-block text-neutral-500 text-xs hover:text-neutral-700 hover:underline">View all posts →</a>
          </div>
        </aside>
      </div>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>

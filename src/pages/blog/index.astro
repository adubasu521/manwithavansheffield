---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/sections/HeroInner.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { blogPosts } from '../../data/blog-posts';
---

<BaseLayout
  title="Moving Tips & Guides for Sheffield | Man With A Van Sheffield Blog"
  description="Moving guides, pricing advice, and local tips for moving in Sheffield and South Yorkshire. Written by our team with years of Sheffield moving experience."
  canonical="https://manwithavansheffield.co.uk/blog/"
>
  <HeroInner
    title="Moving Tips & Guides"
    subtitle="Practical advice from our team — pricing guides, packing tips, and local knowledge for moving in Sheffield."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Blog' }]}
  />

  <Section>
    <Container>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {blogPosts.map((post) => (
          <article class="bg-white rounded-xl shadow-sm border border-neutral-200 overflow-hidden hover:shadow-md transition-shadow group">
            <a href={`/blog/${post.slug}/`}>
              <div class="aspect-video bg-neutral-100 overflow-hidden">
                <img
                  src={post.image}
                  alt={post.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  width="600"
                  height="338"
                  loading="lazy"
                />
              </div>
              <div class="p-6">
                <div class="flex flex-wrap gap-2 mb-3">
                  {post.tags.slice(0, 2).map((tag) => (
                    <span class="text-xs bg-primary-100 text-primary-700 font-medium px-2 py-0.5 rounded">{tag}</span>
                  ))}
                </div>
                <h2 class="text-lg font-bold text-neutral-900 font-heading group-hover:text-primary-600 transition-colors leading-snug">
                  {post.title}
                </h2>
                <p class="mt-2 text-sm text-neutral-600 line-clamp-2">{post.excerpt}</p>
                <div class="mt-4 flex items-center justify-between">
                  <time class="text-xs text-neutral-400" datetime={post.datePublished}>
                    {new Date(post.datePublished).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  <span class="text-primary-600 text-sm font-semibold group-hover:gap-2 flex items-center gap-1">
                    Read more
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </Container>
  </Section>

  <CTASection
    heading="Ready to Book Your Move?"
    subtitle="Get a free, fixed-price quote from our team. Available 7 days a week across Sheffield and South Yorkshire."
  />
</BaseLayout>

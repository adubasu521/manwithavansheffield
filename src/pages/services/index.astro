---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroInner from '../../components/sections/HeroInner.astro';
import ServiceGrid from '../../components/sections/ServiceGrid.astro';
import CTASection from '../../components/sections/CTASection.astro';
import Section from '../../components/ui/Section.astro';
import Container from '../../components/ui/Container.astro';
import { services } from '../../data/services';
---

<BaseLayout
  title="Our Services | Man With A Van Sheffield"
  description="Full list of removal and van hire services in Sheffield. Man and van, house removals, student moves, IKEA delivery, office removals, piano moving and more. Fixed prices, fully insured."
  canonical="https://manwithavansheffield.co.uk/services/"
>
  <HeroInner
    title="Our Services"
    subtitle="From single-item collections to full house removals — fixed prices, fully insured, available 7 days a week across Sheffield and South Yorkshire."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Services' }]}
  />

  <Section>
    <Container>
      <ServiceGrid services={services} />
    </Container>
  </Section>

  <!-- Service Types Overview -->
  <Section class="bg-neutral-50">
    <Container>
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-neutral-900 font-heading">Not Sure Which Service You Need?</h2>
        <p class="mt-4 text-lg text-neutral-600">
          Most Sheffield moves fall into one of our standard categories, but we're happy to discuss your specific situation. Whether you need a two-man team for a full house move or just a driver to help collect a sofa, we've got the right van and crew.
        </p>
        <div class="mt-8 grid sm:grid-cols-2 gap-6 text-left">
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
            <h3 class="font-bold text-neutral-900 text-lg mb-2">Local Sheffield Moves</h3>
            <p class="text-neutral-600 text-sm">For moves within Sheffield or to nearby South Yorkshire towns — fixed price, no hourly meter. We know every gradient street in S1–S36.</p>
            <a href="/services/man-and-van-sheffield/" class="mt-3 inline-block text-primary-600 text-sm font-semibold hover:underline">Man &amp; Van Sheffield →</a>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
            <h3 class="font-bold text-neutral-900 text-lg mb-2">House Removals</h3>
            <p class="text-neutral-600 text-sm">Moving from a 2, 3 or 4-bed house? Our house removal service includes packing options, a Luton van, and a full two-man crew.</p>
            <a href="/services/house-removals-sheffield/" class="mt-3 inline-block text-primary-600 text-sm font-semibold hover:underline">House Removals Sheffield →</a>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
            <h3 class="font-bold text-neutral-900 text-lg mb-2">Long-Distance Moves</h3>
            <p class="text-neutral-600 text-sm">Moving from Sheffield to London, Manchester, Edinburgh or beyond? Direct M1 access from Sheffield makes us ideally placed for UK-wide moves.</p>
            <a href="/services/long-distance-removals-sheffield/" class="mt-3 inline-block text-primary-600 text-sm font-semibold hover:underline">Long-Distance Removals →</a>
          </div>
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
            <h3 class="font-bold text-neutral-900 text-lg mb-2">Specialist Services</h3>
            <p class="text-neutral-600 text-sm">Piano moving through Sheffield's Victorian terraces, fragile items, packing service, IKEA Meadowhall delivery, office relocations — we handle it all.</p>
            <a href="/services/piano-moving-sheffield/" class="mt-3 inline-block text-primary-600 text-sm font-semibold hover:underline">Piano Moving →</a>
          </div>
        </div>
      </div>
    </Container>
  </Section>

  <CTASection />
</BaseLayout>
